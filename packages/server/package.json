{
  "name": "mmo-server",
  "version": "1.0.0",
  "description": "Authoritative MMO server engine",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "postinstall": "node -e \"if(process.env.NODE_ENV==='production'&&require('fs').existsSync('dist/index.js'))console.log('Using pre-built files');else process.exit(1)\""
  },
  "dependencies": {
    "ws": "^8.16.0",
    "better-sqlite3": "^9.4.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4",
    "nanoid": "^5.0.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.9",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
